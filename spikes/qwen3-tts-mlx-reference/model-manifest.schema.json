{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cuttledoc.dev/schemas/qwen3-tts-mlx-reference-model-manifest.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "task",
    "source",
    "conversion",
    "reference_runtime",
    "generation_contract",
    "artifacts",
    "architecture"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "id": {
      "const": "qwen3-tts-12hz-0.6b-customvoice-mlx-bf16"
    },
    "task": {
      "const": "tts"
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "repository",
        "observed_revision",
        "license",
        "supported_languages",
        "provenance_limit"
      ],
      "properties": {
        "repository": {
          "const": "Qwen/Qwen3-TTS-12Hz-0.6B-CustomVoice"
        },
        "observed_revision": {
          "$ref": "#/$defs/revision"
        },
        "license": {
          "const": "Apache-2.0"
        },
        "supported_languages": {
          "$ref": "#/$defs/uniqueStrings"
        },
        "provenance_limit": {
          "$ref": "#/$defs/nonEmptyString"
        }
      }
    },
    "conversion": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "repository",
        "revision",
        "license",
        "format",
        "conversion_tool",
        "conversion_tool_version",
        "parameter_count",
        "weight_bytes",
        "snapshot_bytes"
      ],
      "properties": {
        "repository": {
          "const": "mlx-community/Qwen3-TTS-12Hz-0.6B-CustomVoice-bf16"
        },
        "revision": {
          "$ref": "#/$defs/revision"
        },
        "license": {
          "const": "Apache-2.0"
        },
        "format": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "conversion_tool": {
          "const": "mlx-audio"
        },
        "conversion_tool_version": {
          "const": "0.3.0"
        },
        "parameter_count": {
          "type": "integer",
          "minimum": 1
        },
        "weight_bytes": {
          "type": "integer",
          "minimum": 1
        },
        "snapshot_bytes": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "reference_runtime": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "repository",
        "revision",
        "version",
        "license",
        "boundary"
      ],
      "properties": {
        "repository": {
          "const": "Blaizzy/mlx-audio"
        },
        "revision": {
          "$ref": "#/$defs/revision"
        },
        "version": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "license": {
          "const": "MIT"
        },
        "boundary": {
          "$ref": "#/$defs/nonEmptyString"
        }
      }
    },
    "generation_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "passage_id",
        "locale",
        "language",
        "speaker",
        "speaker_native_language",
        "cross_lingual",
        "instruction",
        "seed",
        "temperature",
        "top_p",
        "top_k",
        "repetition_penalty",
        "max_tokens",
        "sample_rate_hz",
        "rationale"
      ],
      "properties": {
        "passage_id": {
          "const": "synthetic-de-origin"
        },
        "locale": {
          "const": "de-DE"
        },
        "language": {
          "const": "German"
        },
        "speaker": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "speaker_native_language": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "cross_lingual": {
          "const": true
        },
        "instruction": {
          "type": "null"
        },
        "seed": {
          "type": "integer",
          "minimum": 0
        },
        "temperature": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "top_p": {
          "type": "number",
          "exclusiveMinimum": 0,
          "maximum": 1
        },
        "top_k": {
          "type": "integer",
          "minimum": 1
        },
        "repetition_penalty": {
          "type": "number",
          "minimum": 1
        },
        "max_tokens": {
          "type": "integer",
          "minimum": 1
        },
        "sample_rate_hz": {
          "const": 24000
        },
        "rationale": {
          "$ref": "#/$defs/nonEmptyString"
        }
      }
    },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "path",
          "bytes",
          "sha256"
        ],
        "properties": {
          "path": {
            "$ref": "#/$defs/nonEmptyString"
          },
          "bytes": {
            "type": "integer",
            "minimum": 1
          },
          "sha256": {
            "type": "string",
            "pattern": "^[0-9a-f]{64}$"
          }
        }
      }
    },
    "architecture": {
      "type": "object"
    }
  },
  "$defs": {
    "nonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "revision": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    },
    "uniqueStrings": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/nonEmptyString"
      }
    }
  }
}
