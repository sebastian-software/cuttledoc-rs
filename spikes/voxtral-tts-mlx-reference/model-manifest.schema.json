{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cuttledoc.dev/schemas/voxtral-tts-mlx-reference-model-manifest.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "task",
    "source",
    "conversion",
    "reference_runtime",
    "generation_contract",
    "artifacts",
    "architecture"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "id": {
      "const": "voxtral-4b-tts-2603-mlx-4bit"
    },
    "task": {
      "const": "tts"
    },
    "source": {
      "$ref": "#/$defs/openObject"
    },
    "conversion": {
      "type": "object",
      "required": [
        "repository",
        "revision",
        "license",
        "format",
        "conversion_tool",
        "parameter_count",
        "weight_bytes",
        "snapshot_bytes"
      ],
      "properties": {
        "repository": {
          "const": "mlx-community/Voxtral-4B-TTS-2603-mlx-4bit"
        },
        "revision": {
          "$ref": "#/$defs/revision"
        },
        "license": {
          "const": "CC-BY-NC-4.0"
        },
        "format": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "conversion_tool": {
          "const": "mlx-audio"
        },
        "parameter_count": {
          "type": "integer",
          "minimum": 1
        },
        "weight_bytes": {
          "type": "integer",
          "minimum": 1
        },
        "snapshot_bytes": {
          "type": "integer",
          "minimum": 1
        }
      },
      "additionalProperties": false
    },
    "reference_runtime": {
      "$ref": "#/$defs/openObject"
    },
    "generation_contract": {
      "type": "object",
      "required": [
        "passage_id",
        "locale",
        "speaker",
        "speaker_native_language",
        "cross_lingual",
        "seed",
        "temperature",
        "top_p",
        "top_k",
        "max_tokens",
        "sample_rate_hz",
        "rationale"
      ],
      "properties": {
        "passage_id": {
          "const": "synthetic-de-origin"
        },
        "locale": {
          "const": "de-DE"
        },
        "speaker": {
          "const": "de_female"
        },
        "speaker_native_language": {
          "const": "German"
        },
        "cross_lingual": {
          "const": false
        },
        "seed": {
          "type": "integer",
          "minimum": 0
        },
        "temperature": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "top_p": {
          "type": "number",
          "exclusiveMinimum": 0,
          "maximum": 1
        },
        "top_k": {
          "type": "integer",
          "minimum": 1
        },
        "max_tokens": {
          "type": "integer",
          "minimum": 1
        },
        "sample_rate_hz": {
          "const": 24000
        },
        "rationale": {
          "$ref": "#/$defs/nonEmptyString"
        }
      },
      "additionalProperties": false
    },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "path",
          "bytes",
          "sha256"
        ],
        "properties": {
          "path": {
            "$ref": "#/$defs/nonEmptyString"
          },
          "bytes": {
            "type": "integer",
            "minimum": 1
          },
          "sha256": {
            "$ref": "#/$defs/digest"
          }
        },
        "additionalProperties": false
      }
    },
    "architecture": {
      "$ref": "#/$defs/openObject"
    }
  },
  "$defs": {
    "nonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "revision": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    },
    "digest": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "openObject": {
      "type": "object",
      "minProperties": 1
    }
  }
}
