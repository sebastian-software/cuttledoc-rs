{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cuttledoc.dev/schemas/target-domain-asr-drafts.schema.json",
  "title": "Held-out target-domain ASR drafts",
  "description": "Unscored, digest-pinned ASR drafts prepared for independent human-gold review.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "id",
    "status",
    "captured_at",
    "evidence_captured_through",
    "source_revision",
    "runner_sha256",
    "plan",
    "corpus",
    "source_group",
    "audio",
    "host",
    "procedure",
    "results",
    "missing_backends",
    "claim_limit"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "const": "complete"
    },
    "captured_at": {
      "type": "string",
      "format": "date-time"
    },
    "evidence_captured_through": {
      "type": "string",
      "format": "date-time"
    },
    "source_revision": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    },
    "runner_sha256": {
      "$ref": "#/$defs/sha256"
    },
    "plan": {
      "$ref": "#/$defs/pinnedRevision"
    },
    "corpus": {
      "$ref": "#/$defs/pinnedRevision"
    },
    "source_group": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "id",
        "cell_id",
        "split",
        "locale",
        "domain",
        "source_range",
        "attribution"
      ],
      "properties": {
        "split": {
          "const": "validation"
        },
        "source_range": {
          "type": "object",
          "required": [
            "start_ms",
            "end_ms",
            "duration_ms"
          ],
          "properties": {
            "start_ms": {
              "type": "integer",
              "minimum": 0
            },
            "end_ms": {
              "type": "integer",
              "exclusiveMinimum": 0
            },
            "duration_ms": {
              "type": "integer",
              "exclusiveMinimum": 0
            }
          }
        }
      }
    },
    "audio": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "artifact_name",
        "availability",
        "local_path",
        "sha256",
        "bytes",
        "sample_count",
        "sample_rate_hz",
        "channels",
        "sample_format"
      ],
      "properties": {
        "availability": {
          "const": "local-required"
        },
        "local_path": {
          "type": "null"
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        },
        "bytes": {
          "type": "integer",
          "exclusiveMinimum": 0
        },
        "sample_count": {
          "type": "integer",
          "exclusiveMinimum": 0
        },
        "sample_rate_hz": {
          "const": 16000
        },
        "channels": {
          "const": 1
        },
        "sample_format": {
          "const": "float32le"
        }
      }
    },
    "results": {
      "type": "array",
      "minItems": 5,
      "maxItems": 5,
      "items": {
        "$ref": "#/$defs/result"
      }
    },
    "missing_backends": {
      "type": "array",
      "maxItems": 0
    },
    "claim_limit": {
      "type": "string",
      "minLength": 1
    }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "pinnedRevision": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "revision",
        "sha256"
      ],
      "properties": {
        "revision": {
          "type": "string",
          "minLength": 1
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "segment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "start_ms",
        "end_ms",
        "text",
        "confidence"
      ],
      "properties": {
        "start_ms": {
          "type": "number",
          "minimum": 0
        },
        "end_ms": {
          "type": "number",
          "minimum": 0
        },
        "text": {
          "type": "string"
        },
        "confidence": {
          "type": [
            "number",
            "null"
          ]
        }
      }
    },
    "coverage": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "status",
        "method",
        "expected_duration_ms",
        "processed_duration_ms",
        "tolerance_ms",
        "incomplete_reason"
      ],
      "properties": {
        "status": {
          "const": "complete"
        },
        "method": {
          "enum": [
            "final-segment-timestamp",
            "deterministic-fixed-nonoverlap-chunks"
          ]
        },
        "expected_duration_ms": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "processed_duration_ms": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "tolerance_ms": {
          "type": "number",
          "minimum": 0
        },
        "incomplete_reason": {
          "type": "null"
        }
      }
    },
    "quality": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "wer",
        "cer",
        "semantic_errors"
      ],
      "properties": {
        "status": {
          "const": "unscored-human-gold-pending"
        },
        "wer": {
          "type": "null"
        },
        "cer": {
          "type": "null"
        },
        "semantic_errors": {
          "type": "null"
        }
      }
    },
    "result": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "captured_at",
        "backend",
        "transcript",
        "timing",
        "resources",
        "streaming",
        "coverage",
        "quality"
      ],
      "properties": {
        "captured_at": {
          "type": "string",
          "format": "date-time"
        },
        "backend": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "id",
            "model",
            "runtime",
            "boundary"
          ],
          "properties": {
            "id": {
              "type": "string",
              "minLength": 1
            },
            "model": {
              "type": "string",
              "minLength": 1
            },
            "runtime": {
              "type": "string",
              "minLength": 1
            },
            "boundary": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "transcript": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "text",
            "sha256",
            "word_count",
            "segment_count",
            "segments"
          ],
          "properties": {
            "text": {
              "type": "string",
              "minLength": 1
            },
            "sha256": {
              "$ref": "#/$defs/sha256"
            },
            "word_count": {
              "type": "integer",
              "exclusiveMinimum": 0
            },
            "segment_count": {
              "type": "integer",
              "exclusiveMinimum": 0
            },
            "segments": {
              "type": "array",
              "minItems": 1,
              "items": {
                "$ref": "#/$defs/segment"
              }
            }
          }
        },
        "coverage": {
          "$ref": "#/$defs/coverage"
        },
        "quality": {
          "$ref": "#/$defs/quality"
        }
      }
    }
  }
}
