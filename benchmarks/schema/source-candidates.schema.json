{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cuttledoc.dev/schemas/source-candidates.schema.json",
  "title": "Cuttledoc ASR benchmark source candidates",
  "type": "object",
  "required": [
    "schema_version",
    "evidence_date",
    "target_languages",
    "sources"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "evidence_date": {
      "type": "string",
      "format": "date"
    },
    "target_languages": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "status",
          "domains",
          "languages",
          "source_revision",
          "license",
          "redistribution",
          "decision"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "enum": [
              "active-diagnostic",
              "active-development-pilot",
              "selected-for-acquisition",
              "selected-pending-rights-review",
              "selected-as-domain-bridge",
              "acquisition-required"
            ]
          },
          "domains": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "languages": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "source_revision": {
            "type": [
              "string",
              "null"
            ]
          },
          "license": {
            "type": "string",
            "minLength": 1
          },
          "redistribution": {
            "type": "string",
            "minLength": 1
          },
          "decision": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": false
}
