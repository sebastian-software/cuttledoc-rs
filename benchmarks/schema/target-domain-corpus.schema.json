{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cuttledoc.dev/schemas/target-domain-corpus.schema.json",
  "title": "Cuttledoc held-out target-domain corpus selection",
  "type": "object",
  "required": [
    "schema_version",
    "revision",
    "evidence_date",
    "plan_revision",
    "purpose",
    "normalization",
    "cells"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "revision": {
      "type": "string",
      "minLength": 1
    },
    "evidence_date": {
      "type": "string",
      "format": "date"
    },
    "plan_revision": {
      "type": "string",
      "minLength": 1
    },
    "purpose": {
      "const": "held-out"
    },
    "normalization": {
      "type": "object",
      "required": [
        "sample_rate_hz",
        "channels",
        "sample_format",
        "container",
        "decoder"
      ],
      "properties": {
        "sample_rate_hz": {
          "const": 16000
        },
        "channels": {
          "const": 1
        },
        "sample_format": {
          "const": "float32le"
        },
        "container": {
          "const": "raw"
        },
        "decoder": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "cells": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/cell"
      }
    }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "nullableSha256": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^[0-9a-f]{64}$"
    },
    "speaker": {
      "type": "object",
      "required": [
        "id",
        "display_name",
        "role"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "display_name": {
          "type": "string",
          "minLength": 1
        },
        "role": {
          "enum": [
            "host",
            "guest",
            "narrator"
          ]
        }
      },
      "additionalProperties": false
    },
    "artifact": {
      "type": "object",
      "required": [
        "artifact_name",
        "sha256",
        "bytes"
      ],
      "properties": {
        "artifact_name": {
          "type": "string",
          "minLength": 1
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        },
        "bytes": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "sourceGroup": {
      "type": "object",
      "required": [
        "id",
        "source_candidate_id",
        "rights_review_id",
        "rights_review_path",
        "work_kind",
        "title",
        "published_at",
        "locale",
        "domain",
        "split",
        "speakers",
        "source_audio",
        "selection",
        "normalized_audio",
        "published_transcript",
        "gold_transcript",
        "attribution"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "source_candidate_id": {
          "type": "string",
          "minLength": 1
        },
        "rights_review_id": {
          "type": "string",
          "minLength": 1
        },
        "rights_review_path": {
          "type": "string",
          "minLength": 1
        },
        "work_kind": {
          "enum": [
            "episode",
            "work"
          ]
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "published_at": {
          "type": "string",
          "format": "date"
        },
        "locale": {
          "type": "string",
          "minLength": 1
        },
        "domain": {
          "enum": [
            "podcast",
            "audiobook"
          ]
        },
        "split": {
          "enum": [
            "validation",
            "test"
          ]
        },
        "speakers": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/speaker"
          }
        },
        "source_audio": {
          "allOf": [
            {
              "$ref": "#/$defs/artifact"
            },
            {
              "type": "object",
              "required": [
                "source_url",
                "duration_ms"
              ],
              "properties": {
                "source_url": {
                  "type": "string",
                  "format": "uri"
                },
                "duration_ms": {
                  "type": "integer",
                  "minimum": 1
                }
              }
            }
          ]
        },
        "selection": {
          "type": "object",
          "required": [
            "start_ms",
            "end_ms",
            "duration_ms",
            "track_roles"
          ],
          "properties": {
            "start_ms": {
              "type": "integer",
              "minimum": 0
            },
            "end_ms": {
              "type": "integer",
              "minimum": 1
            },
            "duration_ms": {
              "type": "integer",
              "minimum": 1
            },
            "track_roles": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": {
                "enum": [
                  "long-form",
                  "aligned-clip-parent"
                ]
              }
            }
          },
          "additionalProperties": false
        },
        "normalized_audio": {
          "allOf": [
            {
              "$ref": "#/$defs/artifact"
            },
            {
              "type": "object",
              "required": [
                "sample_count",
                "duration_ms"
              ],
              "properties": {
                "sample_count": {
                  "type": "integer",
                  "minimum": 1
                },
                "duration_ms": {
                  "type": "integer",
                  "minimum": 1
                }
              }
            }
          ]
        },
        "published_transcript": {
          "allOf": [
            {
              "$ref": "#/$defs/artifact"
            },
            {
              "type": "object",
              "required": [
                "source_url",
                "status",
                "use"
              ],
              "properties": {
                "source_url": {
                  "type": "string",
                  "format": "uri"
                },
                "status": {
                  "const": "publisher-draft-not-gold"
                },
                "use": {
                  "const": "alignment-and-transcription-aid-only"
                }
              }
            }
          ]
        },
        "gold_transcript": {
          "type": "object",
          "required": [
            "status",
            "artifact_name",
            "sha256",
            "bytes",
            "reviewer_id",
            "reviewed_at",
            "review_record_sha256"
          ],
          "properties": {
            "status": {
              "enum": [
                "pending-independent-human-review",
                "human-verified"
              ]
            },
            "artifact_name": {
              "type": "string",
              "minLength": 1
            },
            "sha256": {
              "$ref": "#/$defs/nullableSha256"
            },
            "bytes": {
              "type": [
                "integer",
                "null"
              ],
              "minimum": 1
            },
            "reviewer_id": {
              "type": [
                "string",
                "null"
              ]
            },
            "reviewed_at": {
              "type": [
                "string",
                "null"
              ],
              "format": "date-time"
            },
            "review_record_sha256": {
              "$ref": "#/$defs/nullableSha256"
            }
          },
          "additionalProperties": false
        },
        "attribution": {
          "type": "object",
          "required": [
            "creators",
            "license",
            "license_url",
            "changes"
          ],
          "properties": {
            "creators": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "license": {
              "type": "string",
              "minLength": 1
            },
            "license_url": {
              "type": "string",
              "format": "uri"
            },
            "changes": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": {
                "type": "string",
                "minLength": 1
              }
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "cell": {
      "type": "object",
      "required": [
        "id",
        "locale",
        "domain",
        "status",
        "summary",
        "source_groups"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "locale": {
          "type": "string",
          "minLength": 1
        },
        "domain": {
          "enum": [
            "podcast",
            "audiobook"
          ]
        },
        "status": {
          "enum": [
            "gold-review",
            "ready",
            "complete"
          ]
        },
        "summary": {
          "type": "object",
          "required": [
            "selected_duration_ms",
            "human_verified_duration_ms",
            "source_group_count",
            "speaker_count"
          ],
          "properties": {
            "selected_duration_ms": {
              "type": "integer",
              "minimum": 1
            },
            "human_verified_duration_ms": {
              "type": "integer",
              "minimum": 0
            },
            "source_group_count": {
              "type": "integer",
              "minimum": 1
            },
            "speaker_count": {
              "type": "integer",
              "minimum": 1
            }
          },
          "additionalProperties": false
        },
        "source_groups": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/sourceGroup"
          }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
