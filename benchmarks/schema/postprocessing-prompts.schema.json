{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cuttledoc.dev/schemas/postprocessing-prompts.schema.json",
  "title": "Cuttledoc postprocessing prompt manifest",
  "type": "object",
  "required": [
    "schema_version",
    "revision",
    "evidence_date",
    "split_policy",
    "prompts"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "revision": {
      "type": "string",
      "minLength": 1
    },
    "evidence_date": {
      "type": "string",
      "format": "date"
    },
    "split_policy": {
      "type": "object"
    },
    "prompts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "path",
          "sha256",
          "source",
          "mode",
          "output_contract",
          "allowed_edit_classes",
          "context_fields",
          "mechanical_gates"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "path": {
            "type": "string",
            "minLength": 1
          },
          "sha256": {
            "type": "string",
            "pattern": "^[0-9a-f]{64}$"
          },
          "source": {
            "type": "string",
            "minLength": 1
          },
          "mode": {
            "enum": [
              "historical-control",
              "surface-only",
              "bounded-lexical",
              "targeted-lexical"
            ]
          },
          "output_contract": {
            "type": "string",
            "minLength": 1
          },
          "allowed_edit_classes": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "context_fields": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "mechanical_gates": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
