{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cuttledoc.dev/schemas/tts-run.schema.json",
  "title": "Cuttledoc speech synthesis diagnostic run",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "captured_at",
    "source_revision",
    "selection_revision",
    "purpose",
    "candidate",
    "host",
    "input",
    "procedure",
    "result",
    "conclusion"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "run_id": {
      "$ref": "#/$defs/nonEmptyString"
    },
    "captured_at": {
      "type": "string",
      "format": "date-time"
    },
    "source_revision": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    },
    "selection_revision": {
      "$ref": "#/$defs/nonEmptyString"
    },
    "purpose": {
      "const": "development-diagnostic"
    },
    "candidate": {
      "type": "object",
      "required": [
        "id",
        "task",
        "voice"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "task": {
          "const": "tts"
        },
        "runtime": {
          "oneOf": [
            {
              "$ref": "#/$defs/nonEmptyString"
            },
            {
              "$ref": "#/$defs/openObject"
            }
          ]
        },
        "model": {
          "$ref": "#/$defs/openObject"
        },
        "boundary": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "model_delivery": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "voice": {
          "$ref": "#/$defs/openObject"
        }
      },
      "additionalProperties": true
    },
    "host": {
      "$ref": "#/$defs/openObject"
    },
    "input": {
      "$ref": "#/$defs/openObject"
    },
    "procedure": {
      "$ref": "#/$defs/openObject"
    },
    "result": {
      "type": "object",
      "required": [
        "status",
        "audio",
        "timing",
        "resources"
      ],
      "properties": {
        "status": {
          "enum": [
            "measured",
            "partial"
          ]
        },
        "audio": {
          "$ref": "#/$defs/openObject"
        },
        "timing": {
          "$ref": "#/$defs/openObject"
        },
        "resources": {
          "$ref": "#/$defs/openObject"
        },
        "lifecycle": {
          "$ref": "#/$defs/openObject"
        },
        "runtime_output": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/openObject"
          }
        },
        "termination": {
          "$ref": "#/$defs/openObject"
        },
        "asr_content_checks": {
          "$ref": "#/$defs/openObject"
        }
      },
      "additionalProperties": false
    },
    "environment_control": {
      "$ref": "#/$defs/openObject"
    },
    "environment": {
      "$ref": "#/$defs/openObject"
    },
    "conclusion": {
      "$ref": "#/$defs/openObject"
    }
  },
  "additionalProperties": false,
  "$defs": {
    "nonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "openObject": {
      "type": "object",
      "minProperties": 1
    }
  }
}
