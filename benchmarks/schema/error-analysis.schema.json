{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cuttledoc.dev/schemas/error-analysis.schema.json",
  "title": "Cuttledoc ASR error analysis",
  "type": "object",
  "required": [
    "schema_version",
    "analysis_id",
    "source_artifacts",
    "normalization",
    "dimensions",
    "review_contract",
    "surface_metrics",
    "candidates"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "analysis_id": {
      "type": "string",
      "minLength": 1
    },
    "source_captured_through": {
      "type": [
        "string",
        "null"
      ]
    },
    "source_artifacts": {
      "type": "array",
      "minItems": 1
    },
    "normalization": {
      "type": "object"
    },
    "dimensions": {
      "type": "object"
    },
    "review_contract": {
      "type": "object"
    },
    "surface_metrics": {
      "type": "object"
    },
    "candidates": {
      "type": "array",
      "minItems": 1
    }
  },
  "additionalProperties": false
}
