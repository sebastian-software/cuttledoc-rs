{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cuttledoc.dev/schemas/synthetic-roundtrip-selection.schema.json",
  "title": "Cuttledoc synthetic roundtrip passage selection",
  "type": "object",
  "required": [
    "schema_version",
    "revision",
    "plan_revision",
    "purpose",
    "text_encoding",
    "paragraph_joiner",
    "spoken_transform",
    "generated_assets",
    "sources"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "revision": {
      "$ref": "#/$defs/nonEmptyString"
    },
    "plan_revision": {
      "$ref": "#/$defs/nonEmptyString"
    },
    "purpose": {
      "const": "diagnostic-materialization"
    },
    "text_encoding": {
      "const": "utf-8"
    },
    "paragraph_joiner": {
      "const": "\n\n"
    },
    "spoken_transform": {
      "const": "none"
    },
    "generated_assets": {
      "const": "lossless-local-opus-repository-after-rights-review"
    },
    "sources": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
       "required": [
         "id",
          "kind",
         "locale",
         "title",
         "revision_url",
          "history_url",
          "license",
          "license_url",
          "attribution",
          "passages"
        ],
        "properties": {
         "id": {
           "$ref": "#/$defs/nonEmptyString"
         },
          "kind": {
            "enum": [
              "mediawiki",
              "repository-authored"
            ]
          },
          "locale": {
            "$ref": "#/$defs/nonEmptyString"
          },
          "api_url": {
            "type": "string",
            "format": "uri"
          },
          "page_id": {
            "type": "integer",
            "minimum": 1
          },
          "title": {
            "$ref": "#/$defs/nonEmptyString"
          },
          "revision_id": {
            "type": "integer",
            "minimum": 1
          },
          "parent_revision_id": {
            "type": "integer",
            "minimum": 1
          },
          "revision_timestamp": {
            "type": "string",
            "format": "date-time"
          },
          "revision_url": {
            "type": "string",
            "format": "uri"
          },
          "history_url": {
            "type": "string",
            "format": "uri"
          },
          "license": {
            "const": "CC-BY-SA-4.0"
          },
          "license_url": {
            "const": "https://creativecommons.org/licenses/by-sa/4.0/"
          },
         "attribution": {
           "$ref": "#/$defs/nonEmptyString"
         },
          "path": {
            "$ref": "#/$defs/nonEmptyString"
          },
          "revision": {
            "type": "string",
            "pattern": "^[0-9a-f]{64}$"
          },
          "passages": {
            "type": "array",
            "minItems": 1,
            "items": {
              "$ref": "#/$defs/passage"
            }
          }
        },
        "allOf": [
          {
            "if": {
              "properties": {
                "kind": { "const": "mediawiki" }
              }
            },
            "then": {
              "required": [
                "api_url",
                "page_id",
                "revision_id",
                "parent_revision_id",
                "revision_timestamp"
              ]
            }
          },
          {
            "if": {
              "properties": {
                "kind": { "const": "repository-authored" }
              }
            },
            "then": {
              "required": [
                "path",
                "revision"
              ]
            }
          }
        ],
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "nonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "passage": {
      "type": "object",
      "required": [
        "id",
        "segments",
        "character_count",
        "verbatim_sha256",
        "spoken_sha256",
        "phenomena"
      ],
      "properties": {
       "id": {
         "$ref": "#/$defs/nonEmptyString"
       },
        "content_type": {
          "$ref": "#/$defs/nonEmptyString"
        },
       "segments": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": [
              "section_path",
              "paragraph_index"
            ],
            "properties": {
              "section_path": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "$ref": "#/$defs/nonEmptyString"
                }
              },
              "paragraph_index": {
                "type": "integer",
                "minimum": 0
              }
            },
            "additionalProperties": false
          }
        },
        "character_count": {
          "type": "integer",
          "minimum": 1
        },
        "verbatim_sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "spoken_sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "phenomena": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/nonEmptyString"
          }
        }
      },
      "additionalProperties": false
    }
  }
}
