{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cuttledoc.dev/schemas/postprocessing-snapshot.schema.json",
  "title": "Cuttledoc historical postprocessing snapshot",
  "type": "object",
  "required": [
    "schema_version",
    "snapshot_id",
    "captured_at",
    "provenance",
    "experiments",
    "conclusions"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "snapshot_id": {
      "type": "string",
      "minLength": 1
    },
    "captured_at": {
      "type": "string",
      "format": "date"
    },
    "provenance": {
      "type": "object"
    },
    "experiments": {
      "type": "array",
      "minItems": 1
    },
    "conclusions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "additionalProperties": false
}
