{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cuttledoc.dev/schemas/postprocessing-factorial-qwen-recovery-plan.schema.json",
  "title": "Cuttledoc Qwen VoiceDesign recovery plan",
  "type": "object",
  "required": [
    "$schema",
    "schema_version",
    "id",
    "plan_id",
    "plan_revision",
    "source_selection_revision",
    "base_qualification",
    "candidate_identity_seeds",
    "selection_policy",
    "targets"
  ],
  "properties": {
    "$schema": { "type": "string" },
    "schema_version": { "const": "1.0.0" },
    "id": { "type": "string", "minLength": 1 },
    "plan_id": { "type": "string", "minLength": 1 },
    "plan_revision": { "type": "string", "minLength": 1 },
    "source_selection_revision": { "type": "string", "minLength": 1 },
    "base_qualification": {
      "type": "object",
      "required": ["path", "sha256", "failed_voice_slots"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "failed_voice_slots": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        }
      },
      "additionalProperties": false
    },
    "candidate_identity_seeds": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "integer", "minimum": 0 }
    },
    "selection_policy": {
      "type": "object",
      "required": [
        "generation_must_finish_before_max_tokens",
        "maximum_qwen_direct_wer",
        "rule"
      ],
      "properties": {
        "generation_must_finish_before_max_tokens": { "const": true },
        "maximum_qwen_direct_wer": { "type": "number", "minimum": 0 },
        "rule": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "targets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["voice_slot_id", "passage_id"],
        "properties": {
          "voice_slot_id": { "type": "string", "minLength": 1 },
          "passage_id": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
