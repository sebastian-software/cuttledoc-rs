  "tracks": {
    "aligned_clip": {
      "minimum_total_duration_ms": 1800000,
      "minimum_source_groups": 3,
      "minimum_speakers": 3,
      "alignment": "human-verified-exact-audio-range"
    },
    "long_form": {
      "minimum_passage_duration_ms": 300000,
      "maximum_passage_duration_ms": 900000,
      "minimum_passages_per_source_group": 1,
      "required_behaviors": [
        "chunking-or-vad",
        "overlap-and-merge",
        "timestamp-continuity",
        "memory-over-time"
      ]
    }
  },
  "split_policy": {
    "grouping_unit": "source-work-or-episode",
    "development": "May influence implementation and prompt design; never contributes held-out acceptance results.",
    "validation": "May tune bounded model, runtime, normalization, or prompt choices; remains source-group disjoint from development and test.",
    "test": "Opened only after the candidate configuration is frozen; remains source-group disjoint from development and validation.",
    "forbid_cross_split_derivatives": true
  },
  "rights_policy": {
    "default_redistribution": "denied",
    "acquisition_gate": "accepted-rights-review",
    "accepted_bases": [
      "explicit-permission",
      "permissive-license",
      "public-domain",
      "user-provided-with-authorization"
    ],
    "separate_audio_and_transcript_evidence": true,
    "local_required_by_default": true,
    "repository_license_is_not_audio_evidence": true
  },
  "gold_policy": {
    "verification": "independent-human-review-against-exact-audio",
    "draft_sources_only": [
      "publisher-transcript",
      "subtitle",
      "book-text",
      "asr-output"
    ],
    "preserve": [
      "verbatim-text",
      "speaker-turns",
      "punctuation",
      "capitalization",
      "numbers",
      "disfluencies",
      "uncertainty"
    ],
    "critical_content": [
      "names-and-terms",
      "numbers-dates-and-units",
      "negation"
    ]
  },
